# SendGrid configuration for registration emails.
# Get your API key from https://app.sendgrid.com/settings/api_keys
# Copy this file to server/.env and fill in the real key.
SENDGRID_API_KEY=SG.your-key-here

# Optional: override the URL used for the "Information for Registered
# Students" link in the guardian confirmation email. Defaults to
# https://www.crania-schools.com/registered-students
# REGISTERED_STUDENTS_URL=https://www.crania-schools.com/registered-students

# Optional: port override (defaults to 4000)
# PORT=4000

# ---- PocketBase ---------------------------------------------
# The Express API talks to PocketBase for all storage. PocketBase
# itself runs as a separate process (see ecosystem.config.cjs).
PB_URL=http://127.0.0.1:8090
PB_ADMIN_EMAIL=admin@craniaverse.local
PB_ADMIN_PASSWORD=change-me-please
